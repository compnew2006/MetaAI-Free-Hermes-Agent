# Meta AI cookie credentials
META_AI_DATR=your_datr_cookie
META_AI_ECTO_1_SESS=your_session_cookie
META_AI_ACCESS_TOKEN=ecto1:your_access_token
META_AI_RD_CHALLENGE=your_rd_challenge

# Optional proxy server options
META_AI_PROXY_ADDR=:8787
META_AI_PROXY_TOKEN=optional-bearer-token

# REST server options
META_AI_REST_ADDR=:8000
META_AI_REST_TOKEN=dev-token
META_AI_CORS_ORIGIN=http://localhost:3000
